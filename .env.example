# ── AI provider (OpenAI primary, OpenRouter fallback) ────
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4.1-nano
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_FALLBACK_ENABLED=true
HYDE_ENABLED=false

OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ingestion sources (optional; fixtures used if blank) ──
TMDB_API_KEY=
RAWG_API_KEY=

# ── Database (Postgres + pgvector) ───────────────────────
POSTGRES_USER=memorylens
POSTGRES_PASSWORD=memorylens
POSTGRES_DB=memorylens
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://memorylens:memorylens@postgres:5432/memorylens

# ── Redis (cache + rate limiting) ────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ── Local AI models ──────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# ── App ──────────────────────────────────────────────────
ENV=development
CORS_ORIGINS=http://localhost:5173
